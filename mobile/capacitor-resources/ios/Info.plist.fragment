<!--
  After `npx cap add ios`, merge these keys into ios/App/App/Info.plist to
  allow the WebView to reach an Ollama LAN server via cleartext HTTP.
  The NSAllowsArbitraryLoadsInWebContent scope is narrower than the global
  arbitrary-loads toggle and is accepted for dev-oriented apps.
-->
<key>NSAppTransportSecurity</key>
<dict>
    <key>NSAllowsArbitraryLoadsInWebContent</key>
    <true/>
    <key>NSAllowsLocalNetworking</key>
    <true/>
</dict>
<key>NSLocalNetworkUsageDescription</key>
<string>SkillOS reaches an Ollama LLM running on your laptop over your local Wi-Fi.</string>
