{
  "name": "skillos-mobile",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "SkillOS Mobile — Pure-JS port with swipe-column visual UX. Runs cartridges and Gallery skills on-device.",
  "scripts": {
    "prebuild": "node scripts/seed-build.mjs && node scripts/copy-wllama.mjs",
    "predev": "node scripts/seed-build.mjs && node scripts/copy-wllama.mjs",
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "node scripts/seed-build.mjs",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.1",
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/lang-yaml": "^6.1.1",
    "@codemirror/language": "^6.10.2",
    "@codemirror/lint": "^6.8.4",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@wllama/wllama": "^2.3.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "codemirror": "^6.0.1",
    "gray-matter": "^4.0.3",
    "idb": "^8.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.5",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^15.7.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.4",
    "tslib": "^2.7.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
