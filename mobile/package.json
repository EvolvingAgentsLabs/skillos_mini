{
  "name": "skillos-mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "skillos_mini — games-first browser playground for the LLM-OS kernel.",
  "scripts": {
    "predev": "node scripts/copy-wllama.mjs && node scripts/copy-strategies.mjs",
    "prebuild": "node scripts/copy-wllama.mjs && node scripts/copy-strategies.mjs",
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@wllama/wllama": "^2.3.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^22.7.5",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.4",
    "tslib": "^2.7.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
