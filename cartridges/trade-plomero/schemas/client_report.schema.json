{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "skillos://_shared/client_report.schema.json",
  "title": "ClientReport",
  "description": "End-of-job report shared with the client (rendered to PDF on-device). Built from blackboard at job close.",
  "type": "object",
  "required": ["summary", "work_done", "professional_disclaimer"],
  "properties": {
    "summary": {
      "type": "string",
      "description": "Plain-language overview for the client. 2-4 sentences."
    },
    "before_photos": {
      "type": "array",
      "items": { "type": "string" }
    },
    "during_photos": {
      "type": "array",
      "items": { "type": "string" }
    },
    "after_photos": {
      "type": "array",
      "items": { "type": "string" }
    },
    "work_done": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "description"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "photos_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "materials_used": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "qty", "unit"],
        "properties": {
          "brand": { "type": "string" },
          "name": { "type": "string" },
          "qty": { "type": "number" },
          "unit": { "type": "string" }
        }
      }
    },
    "warranty_terms": { "type": "string" },
    "follow_up": {
      "type": "object",
      "properties": {
        "needed": { "type": "boolean" },
        "after_days": { "type": "integer", "minimum": 1 },
        "reason": { "type": "string" }
      }
    },
    "professional_disclaimer": {
      "type": "string",
      "description": "Required footer text. Cartridge-specific copy (matriculation status, scope of professional responsibility)."
    },
    "professional": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "business_name": { "type": "string" },
        "matriculation_id": { "type": "string" },
        "matriculated": { "type": "boolean" },
        "phone": { "type": "string" },
        "rut": { "type": "string" }
      }
    }
  }
}
