{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LoadProfile",
  "type": "object",
  "required": ["voltage_v", "rooms"],
  "properties": {
    "voltage_v":    { "type": "integer", "minimum": 110, "maximum": 400 },
    "frequency_hz": { "type": "integer", "enum": [50, 60] },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "loads"],
        "properties": {
          "name": { "type": "string" },
          "loads": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["appliance", "watts", "circuit_type"],
              "properties": {
                "appliance":    { "type": "string" },
                "watts":        { "type": "integer", "minimum": 1 },
                "circuit_type": { "type": "string", "enum": ["lighting", "outlet", "dedicated"] }
              }
            }
          }
        }
      }
    }
  }
}
