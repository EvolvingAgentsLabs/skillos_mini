{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillResult",
  "description": "Result from a Gallery JS skill execution.",
  "type": "object",
  "properties": {
    "result": {
      "type": "string",
      "description": "Text result for the LLM."
    },
    "error": {
      "type": ["string", "null"],
      "description": "Error message if execution failed."
    },
    "webview": {
      "type": "object",
      "description": "Webview to render (url, iframe, aspectRatio).",
      "properties": {
        "url": { "type": "string" },
        "iframe": { "type": "boolean" },
        "aspectRatio": { "type": "number" }
      }
    },
    "image": {
      "type": "object",
      "description": "Image result (base64 encoded).",
      "properties": {
        "base64": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
