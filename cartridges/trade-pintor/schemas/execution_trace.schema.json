{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "skillos://_shared/execution_trace.schema.json",
  "title": "ExecutionTrace",
  "description": "Append-only log of what actually happened on the job. One entry per work_plan step (or ad-hoc deviation).",
  "type": "object",
  "required": ["actions"],
  "properties": {
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_ref", "started_at"],
        "properties": {
          "step_ref": {
            "type": "string",
            "description": "id from work_plan.steps, or 'deviation:<short>' for ad-hoc work."
          },
          "started_at": { "type": "string", "format": "date-time" },
          "ended_at": { "type": "string", "format": "date-time" },
          "photos_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" },
          "voice_notes_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "deviation": {
            "type": "object",
            "description": "Present when reality diverged from plan. Drives a deterministic warn in validators.",
            "properties": {
              "reason": { "type": "string" },
              "kind": { "type": "string", "enum": ["material_swap", "scope_change", "safety_stop", "other"] }
            }
          },
          "outcome": {
            "type": "string",
            "enum": ["completed", "partial", "blocked"]
          }
        }
      }
    }
  }
}
