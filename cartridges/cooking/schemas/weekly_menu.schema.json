{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WeeklyMenu",
  "type": "object",
  "required": ["household_size", "days"],
  "properties": {
    "household_size": { "type": "integer", "minimum": 1 },
    "dietary_notes":  { "type": "string" },
    "days": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "required": ["day", "meals"],
        "properties": {
          "day": { "type": "string" },
          "meals": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "object",
              "required": ["slot", "name", "prep_minutes"],
              "properties": {
                "slot":         { "type": "string", "enum": ["breakfast", "lunch", "dinner"] },
                "name":         { "type": "string", "minLength": 2 },
                "protein":      { "type": "string" },
                "prep_minutes": { "type": "integer", "minimum": 1, "maximum": 120 }
              }
            }
          }
        }
      }
    }
  }
}
